# Copy this file to .env.local and fill in your Supabase project keys.
# Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role secret (Settings > API > service_role). Server-only — required
# for the /admin merchant create/delete routes. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=
